# ── Variablat e nevojshme për prodhim (vendosi në Vercel → Project → Settings → Environment Variables) ──

# Lidhja me bazën e të dhënave PostgreSQL (cloud, p.sh. Neon / Vercel Postgres / Supabase).
# Përdor connection string-un "pooled" për runtime.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Çelësi sekret i NextAuth. Gjenero një të ri: `openssl rand -base64 32`
AUTH_SECRET="ndrysho-kete-me-nje-celes-te-rastesishem"

# URL-ja publike e faqes në prodhim (domeni i Vercel-it ose domeni yt).
AUTH_URL="https://emri-i-projektit.vercel.app"
AUTH_TRUST_HOST=true

# ── Mbrojtja me fjalëkalim për tërë faqen (HTTP Basic Auth) ──
# Nëse SITE_PASSWORD vendoset, çdo vizitor duhet të fusë user/password për të hyrë.
# Lëre bosh lokalisht që faqja të hapet pa pengesë gjatë zhvillimit.
SITE_USER="reklamo"
SITE_PASSWORD="vendos-nje-fjalekalim-te-fortë"
